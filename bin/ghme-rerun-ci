#!/usr/bin/env bash
# ghme-rerun-ci - retrigger a PR's CI by pushing an empty commit to its head
# branch. Works in ghme's launch dir; refuses to push from a diverged/dirty tree.
# Bound to `R` in ~/.config/gh-dash/config.yml.
# Usage: ghme-rerun-ci <pr-number> <head-ref-name>
set -uo pipefail

pr="${1:?usage: ghme-rerun-ci <pr-number> <head-ref-name>}"
head="${2:-}"
dir="${GHME_LAUNCH_DIR:-$PWD}"
msg="re-run ci test"

# Pause so the report is readable before gh-dash repaints. Exit 0 on handled
# problems so gh-dash shows the message, not an error box.
pause() { printf '\nPress Enter to return to ghme '; read -r _ || true; }

cd "$dir" 2>/dev/null || { echo "ghme-rerun-ci: can't enter '$dir'." >&2; pause; exit 0; }

# Check out the PR branch; stop if gh refuses (diverged/dirty) rather than commit
# on top of an unexpected state.
if ! GH_PAGER=cat gh pr checkout "$pr"; then
  echo
  echo "x  Couldn't check out PR #$pr ('$head') cleanly: the local branch has"
  echo "   diverged from the remote, or the working tree is dirty. Sort that out"
  echo "   first; ghme won't push an empty commit from an unknown state."
  pause
  exit 0
fi

if ! git commit --allow-empty -m "$msg"; then
  echo
  echo "x  Couldn't create the empty commit (see the error above)."
  pause
  exit 0
fi

# Bare push: gh pr checkout already set tracking to the PR's head remote.
if GH_PAGER=cat git push; then
  echo
  echo ">  Pushed an empty '$msg' commit to '$head'. CI will re-run from scratch."
else
  echo
  echo "x  Empty commit made locally but the push failed: you may not have push"
  echo "   access to this PR's branch, or it has no upstream set."
  echo "   Undo the local commit with:   git reset --hard HEAD~1"
fi
pause
exit 0
