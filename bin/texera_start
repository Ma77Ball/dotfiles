#!/usr/bin/env bash
# start_app.sh — Texera launcher. Composable targets; pins builds/runs to JDK 17.
#
# Targets (start one or more at once):
#   db        dev postgres (pgroonga) on :5432  — texera_db + texera_iceberg_catalog
#   infra     minio + lakefs (file-service compose)
#   obs       observability stack (VictoriaLogs/Metrics, Jaeger, Parca, OTel collector)
#   app       sbt-built backend services + frontend, in a tmux session (live logs)
#   app-be    backend services only (no frontend) — avoids the ng-serve file watcher
#   dev       convenience = db + infra + app   (obs is separate, run `obs` on its own)
#   debug     full debug pipeline: db + infra + backends + the Amber engine under JDWP
#             on :5005, ready for :TexeraDebug in nvim (runs ./texera_debug)
#   docker    single-node, everything in containers (bin/single-node)
#   k8s       helm install into the current kube context (prod values)
#   fresh     full from-scratch install test: stop everything, wipe the dev DB
#             volume (re-inits from sql/), clean-rebuild the dist, then start dev
#   refresh   non-destructive: rebuild the backend and restart the app on the new
#             build, WITHOUT wiping any data (use after backend code changes)
#
# Usage:
#   ./start_app.sh <target...>        start targets, e.g. `./start_app.sh obs` or `./start_app.sh db infra app`
#   ./start_app.sh stop [target...]   stop targets (no target = stop db+infra+obs+app)
#   ./start_app.sh rebuild [clean]    stop app, then clean sbt dist on JDK 17, unzip launchers (clean by default)
#   ./start_app.sh free-ports         kill whatever is holding the app/frontend ports
#   ./start_app.sh status             show what is up
#   ./start_app.sh attach             attach to the app tmux logs (Ctrl-b n/p switch, Ctrl-b d detach)
#   ./start_app.sh                    interactive: pick targets (space-separated)
#
# Texera requires JDK 17. This script auto-selects one (sdkman 17* candidate, or
# $TEXERA_JAVA_HOME) for builds and service launches without changing your shell
# default. Running on JDK 24+ breaks Hadoop/Iceberg (Subject.getSubject removed).

set -uo pipefail

c_grn=$'\033[32m'; c_red=$'\033[31m'; c_yel=$'\033[33m'; c_dim=$'\033[2m'; c_cyn=$'\033[36m'; c_off=$'\033[0m'
say()  { echo "${c_cyn}==>${c_off} $*"; }
ok()   { echo "  ${c_grn}✓${c_off} $*"; }
warn() { echo "  ${c_yel}!${c_off} $*"; }
die()  { echo "${c_red}error:${c_off} $*" >&2; exit 1; }
need() { command -v "$1" >/dev/null || die "$1 is required but was not found on PATH"; }

# texera_start operates on the Texera checkout you're standing in: walk up from $PWD for
# a dir with build.sbt + amber/. This lives in ~/.local/bin (not in any checkout), so it
# keys off your cwd, not its own location.
_find_root() {
  local d="$PWD"
  while [[ "$d" != / ]]; do
    [[ -f "$d/build.sbt" && -d "$d/amber" ]] && { printf '%s' "$d"; return 0; }
    d="$(dirname "$d")"
  done
  return 1
}
ROOT="$(_find_root)" || die "texera_start: not inside a Texera checkout (no build.sbt above $PWD). cd into texera / texera2 / texera3 first."

# ---- topology --------------------------------------------------------------
SESSION="texera-dev"
INFRA_COMPOSE="$ROOT/file-service/src/main/resources/docker-compose.yml"   # minio + lakefs
SINGLE_NODE="$ROOT/bin/single-node"                                        # full all-container deployment
OBS_COMPOSE="$ROOT/bin/observability/docker-compose.yml"                   # obs entry point (includes single-node)
PG_CONTAINER="texera-dev-postgres"
PG_IMAGE="docker.io/groonga/pgroonga:4.0.1-debian-15"                      # texera_ddl.sql needs pgroonga; fully-qualified so podman resolves it too
OBS_SERVICES=(otel-collector victorialogs victoriametrics jaeger parca parca-agent)
OBS_PROFILES="observability-collector,observability-logs,observability-metrics,observability-traces,observability-profiles"
DEV_BACKENDS=(config-service access-control-service file-service
              workflow-compiling-service computing-unit-managing-service
              texera-web-application computing-unit-master)
# host ports bound by the sbt-built services + frontend (admin connectors
# included). Cleared by 'free-ports' and before 'app' starts so a crashed run
# that orphaned a JVM/ng-serve doesn't wedge the next start with "address in use".
# Docker-managed infra/db/obs ports are NOT here — those are stopped via compose.
APP_PORTS=(8080 8081 8085 2552 8082 8888 9090 9091 9092 9094 9096 4200 1234 3000)
# ports each launched service binds — FIRST is the liveness/health port, the
# rest are also cleared when that service is (re)launched so an orphaned holder
# can't wedge the rebind. computing-unit-master also binds 2552 (pekko remoting
# seed) besides its 8085 HTTP port.
declare -A SVC_PORTS=(
  [config-service]="9094" [access-control-service]="9096" [file-service]="9092"
  [workflow-compiling-service]="9090 9091" [computing-unit-managing-service]="8888 8082"
  [texera-web-application]="8080 8081" [computing-unit-master]="8085 2552" [frontend]="4200"
)

# ---- JDK 17 selection ------------------------------------------------------
JDK17=""
find_jdk17() {
  local c
  if [[ -n "${TEXERA_JAVA_HOME:-}" && -x "$TEXERA_JAVA_HOME/bin/java" ]]; then JDK17="$TEXERA_JAVA_HOME"; return; fi
  for c in "$HOME/.sdkman/candidates/java"/17*; do
    [[ -x "$c/bin/java" ]] && { JDK17="$c"; return; }
  done
  if command -v java >/dev/null && java -version 2>&1 | grep -q 'version "17\.'; then JDK17="${JAVA_HOME:-}"; fi
}
require_jdk17() {
  find_jdk17
  if [[ -z "$JDK17" ]]; then
    warn "no JDK 17 found (set TEXERA_JAVA_HOME or 'sdk install java 17...'). Texera will FAIL on JDK 24+"
    return 1
  fi
  ok "using JDK 17: $JDK17"
}
# run a command under JDK 17 (no-op env if JDK17 is empty)
with_jdk17() { if [[ -n "$JDK17" ]]; then JAVA_HOME="$JDK17" PATH="$JDK17/bin:$PATH" "$@"; else "$@"; fi; }

# ---- Node 24 selection -----------------------------------------------------
# The frontend needs Node >=24 (frontend/package.json "engines" + Angular 21);
# the stock /usr/bin/node is often older. Like the JDK pin above, this picks a
# Node 24 (TEXERA_NODE_HOME, then an nvm v24.*, then any nvm >=24, then the PATH
# node if it already qualifies) for the frontend WITHOUT changing your shell.
NODE24_BIN=""
find_node24() {
  local d v
  if [[ -n "${TEXERA_NODE_HOME:-}" && -x "$TEXERA_NODE_HOME/bin/node" ]]; then NODE24_BIN="$TEXERA_NODE_HOME/bin"; return; fi
  # prefer the highest v24.* from nvm (the LTS line the project targets)
  for d in $(ls -d "$HOME/.nvm/versions/node"/v24.* 2>/dev/null | sort -V -r); do
    [[ -x "$d/bin/node" ]] && { NODE24_BIN="$d/bin"; return; }
  done
  # the PATH node, if it's already >=24
  if command -v node >/dev/null; then
    v="$(node -v 2>/dev/null)"; v="${v#v}"; v="${v%%.*}"
    if [[ "$v" =~ ^[0-9]+$ && "$v" -ge 24 ]]; then NODE24_BIN="$(dirname "$(command -v node)")"; return; fi
  fi
  # any other nvm node >=24 (e.g. v25)
  for d in $(ls -d "$HOME/.nvm/versions/node"/v* 2>/dev/null | sort -V -r); do
    v="$(basename "$d")"; v="${v#v}"; v="${v%%.*}"
    [[ -x "$d/bin/node" && "$v" =~ ^[0-9]+$ && "$v" -ge 24 ]] && { NODE24_BIN="$d/bin"; return; }
  done
}
require_node24() {
  find_node24
  if [[ -z "$NODE24_BIN" ]]; then
    warn "no Node >=24 found (set TEXERA_NODE_HOME or 'nvm install 24'). The frontend (Angular 21) needs it; ng serve may hang or fail to bind :4200 on older Node."
    return 1
  fi
  ok "using Node: $("$NODE24_BIN/node" -v) ($NODE24_BIN)"
}

# ---- container engine (docker if its daemon is up, else rootless podman) ----
# Every container target (db/infra/obs/fresh/single-node) runs on a container
# engine. We do NOT hard-require docker: a dead docker daemon (e.g. Fedora's
# firewalld "INVALID_ZONE: docker" bug, which needs sudo to repair) would block
# every start, including postgres. Rootless podman runs the SAME images with no
# daemon, no firewalld zone, and no sudo, so we fall back to it automatically.
# Preference: a REACHABLE docker daemon first (existing volumes/containers live
# there), else podman. Detection is cached in $CE after the first probe.
CE=""
detect_ce() {
  [[ -n "$CE" ]] && return 0
  if command -v docker >/dev/null 2>&1 && docker info >/dev/null 2>&1; then
    CE=docker
  elif command -v podman >/dev/null 2>&1; then
    CE=podman
    [[ -n "${_ce_warned:-}" ]] || { warn "docker daemon unreachable, using rootless podman (no sudo/firewalld needed)"; _ce_warned=1; }
  elif command -v docker >/dev/null 2>&1; then
    CE=docker   # docker present but daemon down and no podman: let it fail loudly
  else
    return 1
  fi
  return 0
}
need_ce() { detect_ce || die "no container engine: start the docker daemon or install podman"; }
ce()      { need_ce; "$CE" "$@"; }

# `podman compose` drives the external docker-compose provider, which talks to the
# rootless podman API socket. Unlike `podman run`, that socket is NOT auto-started,
# so a compose call dies with "connect: no such file or directory" unless we bring
# it up first (this is why plain `db` works but infra/obs/single-node need this).
# Starts the per-user podman.socket (or a transient `podman system service`),
# waits for it, and exports DOCKER_HOST so the provider connects. No-op on docker.
PODMAN_SOCK=""
# true only if something actually answers on the socket (a stale socket FILE can
# linger after the unit stops, so testing -S alone is not enough).
podman_sock_live() { podman --remote --url "unix://$1" version >/dev/null 2>&1; }
ensure_podman_socket() {
  [[ "$CE" == podman ]] || return 0
  local sock="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/podman/podman.sock"
  if ! podman_sock_live "$sock"; then
    # idempotent: re-binds the listener even if a stale socket file is present
    systemctl --user start podman.socket >/dev/null 2>&1 \
      || { podman system service --time=0 "unix://$sock" >/dev/null 2>&1 & }
    local i; for i in $(seq 1 25); do podman_sock_live "$sock" && break; sleep 0.2; done
  fi
  podman_sock_live "$sock" || { warn "podman API socket not responding at $sock; compose may fail"; return 1; }
  export DOCKER_HOST="unix://$sock"
  [[ -n "$PODMAN_SOCK" ]] || { ok "podman API socket ready ($DOCKER_HOST)"; PODMAN_SOCK="$sock"; }
}

# ---- helpers ---------------------------------------------------------------
port_open() { (exec 3<>"/dev/tcp/127.0.0.1/$1") 2>/dev/null && return 0 || return 1; }
dc() { need_ce; ensure_podman_socket; "$CE" compose -f "$1" "${@:2}"; }
launcher() { find "$ROOT" -maxdepth 5 -type f -path "*/target/*/bin/$1" ! -path '*/universal/*' -perm -u+x 2>/dev/null | sort | head -1; }
have_container() { detect_ce >/dev/null 2>&1 || return 1; "$CE" ps -a --format '{{.Names}}' 2>/dev/null | grep -qx "$1"; }
running_container() { detect_ce >/dev/null 2>&1 || return 1; "$CE" ps --format '{{.Names}}' 2>/dev/null | grep -qx "$1"; }

# Wait for lakeFS to actually serve before we launch backends. file-service runs
# LakeFSStorageClient.healthCheck at boot and exit(1)s if lakeFS isn't reachable
# (FileService.scala). 'docker compose up -d' for infra returns BEFORE lakeFS is
# serving, so a back-to-back app start (fresh/dev/refresh) races it and
# file-service crashes, :9092 goes down, and the UI's /api/dataset/create gets
# ECONNREFUSED ("dataset creation failed"). Poll :8000/_health; warn (don't die)
# if it never comes, so callers without infra aren't blocked hard.
# poll :8000/_health up to $1 seconds (default 60); 0 once healthy, 1 on timeout.
_lakefs_health_wait() {
  command -v curl >/dev/null 2>&1 || { port_open 8000 && return 0 || return 1; }
  local i; for i in $(seq 1 "${1:-60}"); do
    [[ "$(curl -s -o /dev/null -w '%{http_code}' --max-time 3 http://127.0.0.1:8000/_health 2>/dev/null)" == 200 ]] && return 0
    printf '.'; sleep 1
  done
  return 1
}
wait_for_lakefs() {
  printf "  waiting for lakeFS health (:8000)"
  _lakefs_health_wait 30 && { echo; ok "lakeFS healthy (:8000)"; return 0; }
  # Up-but-wedged lakeFS never self-recovers: a crash/restart loop, or a container
  # detached from its docker network after a docker<->podman engine swap (then it
  # can't resolve `postgres` for its KV store). Recreate the infra stack ONCE and
  # re-poll: idempotent, keeps named volumes, only runs when already unhealthy.
  echo; warn "lakeFS not healthy after 30s, recreating infra (likely a wedged container)"
  dc "$INFRA_COMPOSE" up -d --force-recreate >/dev/null 2>&1
  printf "  re-waiting for lakeFS health (:8000)"
  _lakefs_health_wait 60 && { echo; ok "lakeFS healthy (:8000)"; return 0; }
  echo; warn "lakeFS still not healthy on :8000, file-service may crash on startup"
  return 1
}

# ---- port clearing ---------------------------------------------------------
# pids LISTENing on a TCP port — prefer lsof, fall back to ss, then to nothing.
pids_on_port() {
  local p="$1"
  if command -v lsof >/dev/null 2>&1; then
    lsof -t -iTCP:"$p" -sTCP:LISTEN 2>/dev/null
  elif command -v ss >/dev/null 2>&1; then
    ss -ltnpH 2>/dev/null | grep -oE "[:*]$p [^,]*pid=[0-9]+" | grep -oE 'pid=[0-9]+' | cut -d= -f2 | sort -u
  fi
}
# SIGTERM the listener(s) on $1, escalate to SIGKILL if it doesn't release.
free_port() {
  local p="$1" pid procs="" found=0
  for pid in $(pids_on_port "$p"); do
    found=1; procs+="$pid($(ps -p "$pid" -o comm= 2>/dev/null)) "
    kill "$pid" 2>/dev/null
  done
  [[ $found -eq 0 ]] && return 1
  local i
  for i in $(seq 1 10); do port_open "$p" || { ok "freed :$p — was $procs"; return 0; }; sleep 0.3; done
  for pid in $(pids_on_port "$p"); do kill -9 "$pid" 2>/dev/null; done
  sleep 0.3
  port_open "$p" && { warn ":$p still in use after SIGKILL — was $procs"; return 0; } || ok "force-freed :$p — was $procs"
}
free_ports() {
  command -v lsof >/dev/null 2>&1 || command -v ss >/dev/null 2>&1 || { warn "neither lsof nor ss found — cannot free ports"; return; }
  say "clearing app ports"
  local p any=0
  for p in "${APP_PORTS[@]}"; do port_open "$p" && { free_port "$p"; any=1; }; done
  [[ $any -eq 0 ]] && ok "all app ports already free (${APP_PORTS[*]})"
}

# ---- rebuild ---------------------------------------------------------------
rebuild() {
  need sbt; need unzip; require_jdk17 || die "rebuild needs JDK 17"
  local mode="${1:-}"
  local -a cmds=(); [[ -n "$mode" ]] && cmds+=("$mode"); cmds+=(dist)
  say "sbt ${cmds[*]} (JDK 17) — this takes a few minutes…"
  # betterproto prints its progress ("Writing __init__.py", ...) to stderr, which
  # sbt's ProcessLogger tags as [error] even on a clean run. Relabel just those
  # lines to [info] so a successful rebuild doesn't look like it failed. pipefail
  # (set at top) preserves sbt's real exit status, so genuine failures still die.
  with_jdk17 sbt "${cmds[@]}" 2>&1 \
    | sed -uE 's/^\[error\] (Writing )/[info] \1/' \
    || die "sbt dist failed"
  say "unzipping dist launchers"
  local z
  while IFS= read -r z; do unzip -oq "$z" -d "$(dirname "$z")/.."; ok "$(basename "$z")"; done \
    < <(find "$ROOT" -maxdepth 6 -path '*/target/universal/*.zip' ! -path '*/common/*' ! -path '*/node_modules/*' 2>/dev/null | sort)
  ok "rebuild complete"
}
ensure_built() {
  local missing=() n
  for n in "${DEV_BACKENDS[@]}"; do [[ -n "$(launcher "$n")" ]] || missing+=("$n"); done
  [[ ${#missing[@]} -eq 0 ]] && return 0
  warn "missing launchers: ${missing[*]} — building"
  rebuild
}

# ---- fresh (from-scratch install test) -------------------------------------
# Simulates a clean machine: tear the whole dev stack down, drop the Postgres
# data volume so it re-inits from sql/, clean-rebuild the dist on JDK 17, then
# bring infra+app back up. Use to verify a fresh install works end to end.
# WARNING: this WIPES the dev database (workflows, users, projects, dataset
# metadata all live in texera_db). Use 'refresh' for everyday code changes.
#
# DB-BEFORE-BUILD: the sbt build runs JOOQ code generation against a LIVE
# Postgres on :5432 (it introspects the schema to emit the generated table
# classes, e.g. WORKFLOW_COVER_IMAGE). So the freshly-wiped DB must be up and
# re-initialized from sql/ BEFORE 'rebuild clean'. If we build with the DB down,
# codegen fails ("Connection to localhost:5432 refused"), the build silently
# falls back to stale generated classes, any new table is missing, and the clean
# compile dies with "not found: value <TABLE>". That is why we up_db first and
# only start infra+app after the build.
run_fresh() {
  need_ce
  say "fresh: tearing down the dev stack"
  down_app; down_obs
  # WIPE INFRA VOLUMES TOO, not just the DB. 'down_infra' (plain 'compose down')
  # keeps lakeFS + MinIO's named volumes (texera-lakefs_minio_data /
  # _postgres_data), so the object store SURVIVES a fresh DB wipe. That drift is
  # fatal: the re-initialized Texera DB restarts dataset IDs at 1, but lakeFS
  # still holds the old per-dataset repos (dataset-1, dataset-2, ...). Creating
  # or uploading a dataset then fails with lakeFS 409 "error creating
  # repository: not unique" and the upload is rejected. 'down -v' drops the
  # project's volumes so the DB and the object store reset together.
  say "fresh: tearing down infra + wiping lakeFS/MinIO volumes"
  dc "$INFRA_COMPOSE" down -v >/dev/null 2>&1 && ok "minio/lakefs down (volumes wiped)" || ok "infra already down"
  # remove the container + its data volume so the next up_db re-inits from sql/
  have_container "$PG_CONTAINER" && { "$CE" rm -f "$PG_CONTAINER" >/dev/null 2>&1 && ok "removed $PG_CONTAINER"; }
  # Wipe the volume, but DISTINGUISH the failure cases instead of swallowing them.
  # 'volume rm' returns non-zero if another container still references the
  # volume; if we ignore that, the OLD schema survives, up_db mounts it (a
  # non-empty volume does NOT re-run sql/ init), and the build introspects a
  # stale schema -> clean compile fails on whatever tables this branch changed.
  if "$CE" volume inspect texera-dev-pgdata >/dev/null 2>&1; then
    "$CE" volume rm texera-dev-pgdata >/dev/null 2>&1 \
      && ok "wiped DB volume texera-dev-pgdata (will re-init from sql/)" \
      || die "could not remove volume texera-dev-pgdata: another container still references it, so the old schema would survive. Find + remove it: $CE ps -a --filter volume=texera-dev-pgdata"
  else
    ok "DB volume already absent (will re-init from sql/)"
  fi
  # GUARD: fresh must build against ITS OWN freshly-initialized DB. up_db reuses
  # whatever already listens on :5432 ("postgres already on :5432, using it").
  # Having just removed our own $PG_CONTAINER, anything STILL on :5432 is foreign:
  # a texera_postgres checkout, a leftover '--offset' instance, or another
  # texera* checkout's dev DB. JOOQ would then generate classes from THAT
  # database's schema (a different branch) and the clean compile would fail
  # non-deterministically. Refuse rather than silently poison the build.
  if port_open 5432; then
    die "fresh: something other than $PG_CONTAINER is already serving :5432 (we just removed ours). The build would generate JOOQ classes from that DB's schema, not this branch's sql/. Stop it first ($CE ps --filter publish=5432), then re-run 'texera_start fresh'."
  fi
  # bring the wiped DB up first so JOOQ codegen sees the fresh schema (see above).
  # the postgres image only opens :5432 after its sql/ init scripts finish, so
  # up_db's port wait guarantees the schema is loaded before we build.
  say "fresh: starting db (re-inits from sql/), needed for JOOQ codegen before the build"
  up_db
  port_open 5432 || die "fresh: postgres never opened :5432, so JOOQ codegen cannot run. Check: $CE logs $PG_CONTAINER"
  # Wipe the gitignored jOOQ-generated sources so the clean rebuild regenerates
  # them from THIS DB's exact schema. They are NOT cleaned by 'sbt clean' (they
  # live under src/, not target/), so a table file left over from a different
  # schema (e.g. a stale Feedback.java when the fresh DB has no feedback table,
  # or vice-versa) survives the build: jOOQ rewrites Keys.java for the current
  # schema while the stale table file still references keys that no longer exist,
  # and javac dies with "cannot find symbol FEEDBACK_PKEY ... class Keys". Safe
  # here because up_db just confirmed :5432 is serving, so codegen regenerates
  # the full package rather than falling back to the (now-deleted) stale files.
  local jooq_gen="$ROOT/common/dao/src/main/scala/org/apache/texera/dao/jooq/generated"
  [[ -d "$jooq_gen" ]] && { rm -rf "$jooq_gen" && ok "cleared stale jOOQ generated sources (regenerate from fresh schema)"; }
  rebuild clean
  say "fresh: starting dev (infra + app)"
  local t
  for t in infra app; do start_target "$t"; done
}

# ---- dev DB schema sync (non-destructive) ----------------------------------
# Run psql against the dev DB, engine-agnostic: exec inside our own postgres
# container if it's the one serving :5432, else fall back to a host psql client.
# Returns 127 if neither is available so callers can warn instead of hanging.
# stdin is forwarded, so callers can pipe a .sql file in.
_psql() {
  if running_container "$PG_CONTAINER"; then
    "$CE" exec -i "$PG_CONTAINER" psql "$@"
  elif command -v psql >/dev/null 2>&1; then
    PGPASSWORD=postgres psql -h 127.0.0.1 -p 5432 "$@"
  else
    return 127
  fi
}
# sorted list of tables in the texera_db schema (one per line)
_db_tables() { _psql -U postgres -d texera_db -tAqc \
  "SELECT tablename FROM pg_tables WHERE schemaname='texera_db' ORDER BY 1;" 2>/dev/null; }

# JOOQ codegen during the sbt build introspects the LIVE :5432 schema to emit the
# generated table classes (WORKFLOW_COVER_IMAGE, FEEDBACK, ...). 'refresh' keeps
# the existing DB volume, and a non-empty Postgres volume does NOT re-run sql/ on
# start, so any table ADDED to sql/texera_ddl.sql since this DB was first
# initialized is missing from the live schema. Codegen then can't emit its class
# and the build dies "not found: value <TABLE>" (and silently falls back to stale
# generated files in the meantime). This brings the live schema up to date with
# sql/texera_ddl.sql WITHOUT wiping data: we strip every DROP DATABASE/TABLE/TYPE
# and CREATE DATABASE line, leaving only the idempotent CREATE TABLE IF NOT EXISTS
# (plus CREATE TYPE/INDEX that error harmlessly when the object already exists).
# Existing tables are never dropped, so their data is preserved; only the missing
# tables get created. Column-level changes to existing tables are NOT covered by
# CREATE TABLE IF NOT EXISTS, so those still need a 'fresh' (the build's readable
# error in run_refresh tells the user exactly that).
sync_dev_schema() {
  port_open 5432 || { warn "postgres not on :5432, cannot sync schema; JOOQ codegen may miss new tables"; return 0; }
  local ddl="$ROOT/sql/texera_ddl.sql"
  [[ -f "$ddl" ]] || { warn "sql/texera_ddl.sql not found, skipping schema sync"; return 0; }
  detect_ce >/dev/null 2>&1
  if ! running_container "$PG_CONTAINER" && ! command -v psql >/dev/null 2>&1; then
    warn "cannot reach postgres ($PG_CONTAINER not running and no host psql), skipping schema sync; codegen may miss new tables"
    return 0
  fi
  say "syncing dev DB schema from sql/texera_ddl.sql (adds missing tables; data preserved)"
  local before after added
  before="$(_db_tables)"
  # ON_ERROR_STOP=0: pre-existing CREATE TYPE/INDEX/SCHEMA lines error harmlessly.
  # The file's own \c switches into texera_db, so connect to the postgres maint DB.
  grep -viE '^[[:space:]]*(DROP[[:space:]]+(DATABASE|TABLE|TYPE)|CREATE[[:space:]]+DATABASE)' "$ddl" \
    | _psql -v ON_ERROR_STOP=0 -U postgres -d postgres -q >/dev/null 2>&1
  after="$(_db_tables)"
  added="$(comm -13 <(printf '%s\n' "$before") <(printf '%s\n' "$after") | grep -v '^$' | paste -sd' ' -)"
  if [[ -n "$added" ]]; then ok "schema synced, added: $added"; else ok "schema already up to date"; fi
}

# ---- refresh (non-destructive rebuild + restart) ---------------------------
# Everyday "I changed backend code, show me the change" command. Recompiles and
# relaunches the app on the new build WITHOUT touching any data: no DB wipe, no
# volume removal. The frontend's ng serve already hot-reloads, so this is mainly
# for backend Scala/Java edits, which 'dev'/'app' do NOT pick up on their own
# (they only build when launchers are missing). Incremental build by default;
# pass 'clean' for a full rebuild. Brings db+infra up if down (both idempotent,
# never destructive).
run_refresh() {
  local mode="${1:-}"
  say "refresh: rebuild + restart (data preserved, no wipe)"
  down_app                 # stop services so they relaunch on the new build
  # DB must be up BEFORE the build: JOOQ codegen introspects the live :5432 schema
  # to emit the generated table classes. (Previously up_db ran AFTER rebuild, so a
  # boot with the DB down made codegen silently fall back to stale classes.)
  up_db
  # bring the live schema up to date with sql/ so codegen sees newly added tables
  # (e.g. workflow_cover_image, feedback). Non-destructive, see sync_dev_schema.
  sync_dev_schema
  # Build with a readable failure: if codegen still can't find a table, the dev DB
  # is behind sql/ in a way the additive sync cannot fix (a column change/rename),
  # so point the user at 'fresh' instead of dumping a raw Scala compile error.
  local log="${TMPDIR:-/tmp}/texera-refresh-build.log"
  if ! ( rebuild "$mode" ) 2>&1 | tee "$log"; then
    echo
    if grep -q "not found: value [A-Z]" "$log"; then
      local missing
      missing="$(grep -oE "not found: value [A-Z_]+" "$log" | sed 's/not found: value //' | sort -u | paste -sd', ' -)"
      die "refresh build failed: JOOQ codegen is missing table(s) [$missing] from the dev DB.
  The auto schema-sync only ADDS new tables; a column change or rename to an
  existing table needs a full reset. Fix with 'texera_start fresh' (WARNING:
  this WIPES the dev DB), or apply the matching sql/updates/*.sql to the running
  postgres by hand, then re-run 'texera_start refresh'."
    fi
    die "refresh build failed, see the build output above (full log: $log)."
  fi
  up_infra                 # ensure runtime deps are up (idempotent; never wipes a volume)
  up_app yes
}

# ---- db --------------------------------------------------------------------
up_db() {
  if port_open 5432; then ok "postgres already on :5432, using it"; return; fi
  need_ce
  if have_container "$PG_CONTAINER"; then "$CE" start "$PG_CONTAINER" >/dev/null
  else
    say "starting dev postgres ($PG_IMAGE) on :5432 via $CE, init from sql/"
    # ':ro,z' relabels the bind-mounted sql/ for SELinux (Enforcing on Fedora) so
    # rootless podman can read the init scripts; docker accepts the flag too.
    "$CE" run -d --name "$PG_CONTAINER" \
      -e POSTGRES_USER=postgres -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=postgres \
      -p 5432:5432 -v "$ROOT/sql:/docker-entrypoint-initdb.d:ro,z" \
      -v texera-dev-pgdata:/var/lib/postgresql/data "$PG_IMAGE" >/dev/null
  fi
  printf "  waiting for postgres"; local i
  for i in $(seq 1 30); do port_open 5432 && break; printf '.'; sleep 1; done; echo
  port_open 5432 && ok "postgres up (:5432)" || warn "postgres did not open :5432, check: $CE logs $PG_CONTAINER"
}
down_db() {
  if running_container "$PG_CONTAINER"; then "$CE" stop "$PG_CONTAINER" >/dev/null && ok "dev postgres stopped (volume kept; '$CE rm $PG_CONTAINER' to reset)"
  else ok "dev postgres not running"; fi
}

# ---- infra (minio + lakefs) ------------------------------------------------
up_infra()   { need_ce; say "minio + lakefs"; dc "$INFRA_COMPOSE" up -d && ok "minio :9000/:9001, lakefs :8000"; }
down_infra() { need_ce; dc "$INFRA_COMPOSE" down >/dev/null 2>&1 && ok "minio/lakefs down"; }

# ---- observability ---------------------------------------------------------
up_obs() {
  need_ce; ensure_podman_socket; say "observability stack"
  COMPOSE_PROFILES="$OBS_PROFILES" dc "$OBS_COMPOSE" up -d "${OBS_SERVICES[@]}" \
    && ok "logs :9428  metrics :8428  traces :16686  profiles :7070  otlp :4317"
}
down_obs() {
  need_ce; ensure_podman_socket
  COMPOSE_PROFILES="$OBS_PROFILES" dc "$OBS_COMPOSE" stop "${OBS_SERVICES[@]}" >/dev/null 2>&1 && ok "observability stopped"
}

# ---- app (sbt services + frontend in tmux, on JDK 17) ----------------------
ensure_session() { tmux has-session -t "$SESSION" 2>/dev/null || tmux new-session -d -s "$SESSION" -n _ "while :; do sleep 3600; done"; }
win() { echo "${1//[^A-Za-z0-9_-]/_}"; }
win_exists() { tmux list-windows -t "$SESSION" -F '#W' 2>/dev/null | grep -qx "$(win "$1")"; }
# A window counts as "alive" only if it exists AND its health port is listening.
# The dist launchers are bash wrappers (java runs as a child), so the pane's
# foreground command is always `bash` — pane_current_command can't tell live
# from crashed. The bound port can: a crashed/exited service releases it.
win_alive() {  # name  [healthport]
  local name="$1" port="${2:-}"
  win_exists "$name" || return 1
  [[ -n "$port" ]] || return 0           # no port to probe — assume the window means alive
  port_open "$port"
}
launch() {  # name  cwd  command  [ports...]   (first port is the health port)
  local name="$1" cwd="$2" cmd="$3"; shift 3
  local ports=("$@") w; w="$(win "$name")"
  ensure_session
  win_alive "$name" "${ports[0]:-}" && { ok "$name already running"; return; }
  win_exists "$name" && tmux kill-window -t "$SESSION:$w" 2>/dev/null   # clear a dead/crashed window
  local p; for p in "${ports[@]}"; do port_open "$p" && free_port "$p"; done  # clear orphans on all its ports
  tmux new-window -t "$SESSION" -n "$w" \
    "cd '$cwd' && $cmd; ec=\$?; echo; echo '[$name exited ('\$ec') — Ctrl-b & to close]'; read"
  ok "started $name"
}
up_app() {
  local with_frontend="${1:-yes}"   # pass 'no' to launch backend services only
  need tmux; require_jdk17 || true
  ensure_built
  local java_env=""; [[ -n "$JDK17" ]] && java_env="JAVA_HOME='$JDK17'"
  local pyenv=""; [[ -x "$ROOT/../venv312/bin/python" ]] && pyenv="UDF_PYTHON_PATH='$ROOT/../venv312/bin/python'"
  # config-service/file-service/etc. resolve their dropwizard yaml as
  # $TEXERA_HOME/<service>/src/main/resources/... (default "."). Launched from
  # the service dir, an unset TEXERA_HOME doubles the path (.../config-service/./config-service/...)
  # and the service dies "config not found". Pin it to the repo root.
  local home_env="TEXERA_HOME='$ROOT'"
  # Backend log level. Defaults to TRACE so trace/debug logs surface in the
  # observability logs panel; export TEXERA_SERVICE_LOG_LEVEL to override
  # (e.g. `TEXERA_SERVICE_LOG_LEVEL=INFO texera_start app` to quiet the
  # framework firehose). Forwarded via env because tmux windows don't inherit
  # the caller's shell env reliably.
  local log_env="TEXERA_SERVICE_LOG_LEVEL='${TEXERA_SERVICE_LOG_LEVEL:-TRACE}'"
  # If infra (lakeFS) is up, wait for it to actually serve before launching
  # backends: file-service health-checks lakeFS at boot and crashes if it loses
  # the race (see wait_for_lakefs). No-op when lakeFS isn't running (e.g. app-be
  # without infra), so this never blocks a backend-only start.
  running_container texera-lakefs-lakefs && wait_for_lakefs || true
  local n path
  for n in "${DEV_BACKENDS[@]}"; do
    path="$(launcher "$n")"
    [[ -n "$path" ]] || { warn "no launcher for $n — skipping"; continue; }
    launch "$n" "${path%/target/*}" "env $home_env $java_env $pyenv $log_env '$path'" ${SVC_PORTS[$n]:-}
    sleep 1; [[ "$n" == config-service ]] && sleep 2
  done
  if [[ "$with_frontend" == yes && -f "$ROOT/frontend/package.json" ]]; then
    need yarn; require_node24 || true
    # prepend the Node 24 bin to PATH for the frontend window so yarn/ng/npx
    # resolve the right node. $PATH stays literal so it expands in that shell.
    local node_env=""; [[ -n "$NODE24_BIN" ]] && node_env="PATH=$NODE24_BIN:\$PATH "
    launch frontend "$ROOT/frontend" "${node_env}yarn start" ${SVC_PORTS[frontend]}
    echo; ok "app launched — frontend http://localhost:4200  web API http://localhost:8080"
  else
    echo; ok "backend launched — web API http://localhost:8080 (frontend not started)"
  fi
  echo "  logs: ./start_app.sh attach   stop: ./start_app.sh stop app"
}
down_app() { tmux kill-session -t "$SESSION" 2>/dev/null && ok "app services stopped" || ok "app not running"; }
attach()   { tmux has-session -t "$SESSION" 2>/dev/null || die "no app session running"; tmux attach -t "$SESSION"; }

# ---- docker single-node ----------------------------------------------------
# bin/single-node/up.sh execs `docker compose` directly. Under podman we just need
# the API socket up + DOCKER_HOST exported (ensure_podman_socket), so the v2 binary
# drives podman instead of a dead docker daemon. No-op under docker.
ensure_compose_engine() { need_ce; ensure_podman_socket; }
run_docker() {
  ensure_compose_engine; say "single-node (all containers) via $CE"
  [[ -x "$SINGLE_NODE/up.sh" ]] || die "bin/single-node/up.sh not found"
  ( cd "$SINGLE_NODE" && ./up.sh -d ) || die "compose up failed"
  ok "UI http://localhost:8080 (texera/texera). logs: cd bin/single-node && $CE compose logs -f"
}
down_docker() { ensure_compose_engine; ( cd "$SINGLE_NODE" && "$CE" compose down ) && ok "single-node down"; }

# ---- kubernetes (helm, prod values) ----------------------------------------
run_k8s() {
  need helm; need kubectl; local chart="$ROOT/bin/k8s"
  say "helm install (context: $(kubectl config current-context 2>/dev/null || echo '?'))"
  helm dependency build "$chart" || die "helm dependency build failed"
  helm upgrade --install texera "$chart" -f "$chart/values.yaml" || die "helm install failed"
  ok "release 'texera' applied. watch: kubectl get pods -w"
}
down_k8s() { need helm; helm uninstall texera && ok "helm release 'texera' removed"; }

# ---- status ----------------------------------------------------------------
status() {
  find_jdk17
  say "Texera status"
  echo "  JDK 17:     ${JDK17:-${c_red}none, getSubject will fail on 24+${c_off}}"
  detect_ce >/dev/null 2>&1
  printf "  engine:     "; [[ -n "$CE" ]] && echo "${c_grn}$CE${c_off}" || echo "${c_red}none (no docker daemon / podman)${c_off}"
  local c
  printf "  db:         "; port_open 5432 && echo "${c_grn}:5432 reachable${c_off}" || echo "${c_dim}down${c_off}"
  printf "  infra:      "; running_container texera-lakefs-minio && echo "${c_grn}up${c_off}" || echo "${c_dim}down${c_off}"
  printf "  observ.:    "; running_container texera-victorialogs && echo "${c_grn}up${c_off}" || echo "${c_dim}down${c_off}"
  printf "  app (tmux): "; tmux has-session -t "$SESSION" 2>/dev/null && tmux list-windows -t "$SESSION" -F '#W' 2>/dev/null | grep -v '^_$' | paste -sd' ' - || echo "${c_dim}down${c_off}"
  local p busy=()
  for p in "${APP_PORTS[@]}"; do port_open "$p" && busy+=("$p"); done
  printf "  app ports:  "; [[ ${#busy[@]} -eq 0 ]] && echo "${c_dim}all free${c_off}" || echo "${c_yel}in use: ${busy[*]}${c_off} (./start_app.sh free-ports)"
}

# ---- debug pipeline --------------------------------------------------------
# `texera_start debug`: db + infra + backends, then relaunch the Amber engine under a
# JDWP debugger on :5005 so you can attach (:TexeraDebug in nvim, or IntelliJ remote).
run_debug() {
  local port="${TEXERA_DEBUG_PORT:-5005}"
  if [[ "${1:-}" == stop ]]; then
    tmux kill-window -t "$SESSION:cum-debug" 2>/dev/null; down_app; return
  fi
  require_jdk17 || true
  up_db; up_infra
  # wait for lakeFS health BEFORE backends so file-service doesn't race it and crash
  say "waiting for lakeFS health (:8000) before backends..."
  local i
  for i in $(seq 1 60); do
    [[ "$(curl -s -o /dev/null -w '%{http_code}' --max-time 3 http://127.0.0.1:8000/_health 2>/dev/null)" == 200 ]] && break
    sleep 1
  done
  up_app no          # backend services, no frontend
  say "waiting for backends to be healthy..."
  for i in $(seq 1 90); do
    local up=1 p
    for p in 9094 9096 9092 9090 8888 8080; do port_open "$p" || { up=0; break; }; done
    [[ "$up" == 1 ]] && break; sleep 2
  done
  local L; L="$(launcher computing-unit-master)"
  [[ -n "$L" ]] || die "no computing-unit-master launcher (run: texera_start rebuild)"
  say "relaunching the engine under the debugger (JDWP :$port)..."
  local p
  for p in 8085 2552 "$port"; do port_open "$p" && free_port "$p"; done
  sleep 2
  ensure_session
  tmux new-window -t "$SESSION" -n cum-debug -c "$ROOT/amber" \
    "env TEXERA_HOME='$ROOT' JAVA_HOME='$JDK17' '$L' -jvm-debug $port"
  for i in $(seq 1 60); do port_open "$port" && break; sleep 1; done
  echo
  if port_open "$port"; then ok "engine running under the debugger - JDWP on localhost:$port"
  else warn "engine not on :$port yet - watch it: texera_start attach (window cum-debug)"; fi
  cat <<EOF

Attach from nvim (current editor):
  :luafile $ROOT/profiling/nvim_tuple_debug.lua   (sets breakpoints + dap configs)
  :TexeraDebug                                      (attach + set breakpoints)
Then set breakpoints (<leader>b) and Run a workflow (web UI, or profiling/tx_client.py).
Stop the debug engine:  texera_start debug stop
EOF
}

# ---- target dispatch -------------------------------------------------------
start_target() {
  case "$1" in
    db)    up_db ;;
    infra) up_infra ;;
    obs|observability) up_obs ;;
    app)   up_app yes ;;
    app-be|backend) up_app no ;;
    docker|single) run_docker ;;
    k8s|kubernetes)  run_k8s ;;
    *) die "unknown target: $1 (db|infra|obs|app|app-be|dev|debug|docker|k8s)" ;;
  esac
}
stop_target() {
  case "$1" in
    db)    down_db ;;
    infra) down_infra ;;
    obs|observability) down_obs ;;
    app|app-be|backend)   down_app ;;
    docker|single) down_docker ;;
    k8s|kubernetes)  down_k8s ;;
    *) die "unknown target: $1" ;;
  esac
}
# expand 'dev' and normalize order so dependencies come up first
expand_targets() {
  local t out=()
  for t in "$@"; do
    case "$t" in
      dev)           out+=(db infra app) ;;   # obs is its own target now
      backend)       out+=(app-be) ;;
      observability) out+=(obs) ;;
      single)        out+=(docker) ;;
      kubernetes)    out+=(k8s) ;;
      *)             out+=("$t") ;;
    esac
  done
  # unique, in canonical order (app-be before app so backend-only wins if both given)
  local order=(db infra obs app-be app docker k8s) o
  for o in "${order[@]}"; do printf '%s\n' "${out[@]}" | grep -qx "$o" && echo "$o"; done
}

# ---- entrypoint ------------------------------------------------------------
cmd="${1:-}"
case "$cmd" in
  ""|menu)
    echo "${c_cyn}Texera launcher${c_off} — targets (space-separated, e.g. 'obs' or 'db infra app' or 'dev'):"
    echo "  ${c_grn}db${c_off} postgres   ${c_grn}infra${c_off} minio+lakefs   ${c_grn}obs${c_off} observability   ${c_grn}app${c_off} services+frontend"
    echo "  ${c_grn}app-be${c_off} backend only (no frontend)   ${c_grn}dev${c_off} = db+infra+app"
    echo "  ${c_grn}debug${c_off} = full pipeline, engine under JDWP on :5005 (then :TexeraDebug in nvim)"
    echo "  ${c_grn}docker${c_off} single-node    ${c_grn}k8s${c_off} helm"
    echo "  ${c_grn}fresh${c_off} = wipe DB + clean rebuild + start dev (from-scratch install test)"
    echo "  ${c_grn}refresh${c_off} = rebuild + restart app, no data wipe (after code changes)"
    read -rp "start> " line
    [[ -n "${line:-}" ]] || die "nothing selected"
    read -ra TGTS <<< "$line"
    for t in $(expand_targets "${TGTS[@]}"); do start_target "$t"; done
    ;;
  stop|down)
    shift
    if [[ $# -eq 0 ]]; then set -- dev; fi   # default: tear down the local dev stack
    # stop in reverse dependency order (app first, db last)
    mapfile -t T < <(expand_targets "$@" | tac)
    for t in "${T[@]}"; do stop_target "$t"; done
    ;;
  debug)   shift; run_debug "$@" ;;   # full debug pipeline (engine under JDWP on :5005)
  fresh)   run_fresh ;;               # wipe DB + clean rebuild + start dev (from-scratch install test)
  refresh) shift; run_refresh "${1:-}" ;;   # non-destructive: rebuild + restart app, no data wipe
  rebuild) shift; down_app; rebuild "${1:-clean}" ;;   # stop app first; clean build by default
  attach)  attach ;;
  status)  status ;;
  free-ports|free|clear-ports|clear) free_ports ;;
  -h|--help|help) sed -n '2,30p' "$0" ;;
  *)
    # one or more start targets
    for t in $(expand_targets "$@"); do start_target "$t"; done
    ;;
esac
